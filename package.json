{
  "name": "interactive-seating-map-user-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @interactive-seating-map/web --filter @interactive-seating-map/api dev",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,yml,yaml}\"",
    "fixture:large": "node scripts/generate-large-venue.mjs",
    "lint": "pnpm -r lint",
    "setup:githooks": "git config core.hooksPath .githooks",
    "safe-push": "sh scripts/safe-push.sh",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @interactive-seating-map/shared build && pnpm -r typecheck",
    "verify:push": "sh scripts/verify-push.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  }
}
