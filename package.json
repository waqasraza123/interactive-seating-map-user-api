{
  "name": "interactive-seating-map-user-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @interactive-seating-map/web --filter @interactive-seating-map/api dev",
    "lint": "pnpm -r lint",
    "setup:githooks": "git config core.hooksPath .githooks",
    "safe-push": "sh scripts/safe-push.sh",
    "typecheck": "pnpm -r typecheck",
    "verify:push": "sh scripts/verify-push.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
